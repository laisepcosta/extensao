{
  "manifest_version": 3,
  "name": "Assistente - Cessão de Crédito",
  "version": "2.0",
  "description": "Analisa cessões de crédito em precatórios com IA local.",
  "permissions": [
    "sidePanel",
    "clipboardWrite",
    "downloads",
    "cookies",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://eproc.tjmg.jus.br/*",
    "https://eproc2g.tjmg.jus.br/*"
  ],
  "action": {
    "default_title": "Abrir Assistente de Cessão",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "side_panel": {
    "default_path": "ui/popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://eproc.tjmg.jus.br/*",
        "https://eproc2g.tjmg.jus.br/*"
      ],
      "js": [
        "content_scripts/eproc.js"
      ],
      "run_at": "document_idle"
    }
  ]
}